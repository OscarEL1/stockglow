{
    "name": "stockglow",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "description": "SaaS de gestión de inventario para Tiendas de Cosmeticos",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "scripts": {
        "dev:api": "pnpm --filter api dev",
        "dev:web": "pnpm --filter web dev",
        "lint": "pnpm -r lint",
        "typecheck": "pnpm -r typecheck",
        "test": "pnpm -r test",
        "prepare": "husky"
    },
    "lint-staged": {
        "apps/api/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ],
        "apps/web/**/*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "packages/shared/**/*.ts": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "prettier": "^3.8.3",
        "typescript-eslint": "^8.60.1"
    }
}