    "@fastify/helmet": "13.0.1",
    "@fastify/jwt": "9.1.0",
    "@fastify/multipart": "9.0.3",
    "@fastify/rate-limit": "11.0.0",
    "@fastify/swagger": "9.4.0",
    "@fastify/swagger-ui": "5.2.1",
    "@fastify/websocket": "11.0.2",
    "@prisma/client": "6.8.2",
    "@upstash/redis": "1.34.3",
    "cloudinary": "2.6.1",
    "dotenv": "16.5.0",
    "fastify": "5.3.2",
    "fastify-plugin": "5.0.1",
    "svix": "^1.96.1",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "@types/ws": "8.5.14",
