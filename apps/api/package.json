{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "StockGlow API - Fastify Backend",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
