generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id               String    @id @default(uuid())
  nombreTienda     String    @map("nombre_tienda") @db.VarChar(100)
  logoUrl          String?   @map("logo_url")
  planSuscripcion  String    @default("basic") @map("plan_suscripcion") @db.VarChar(20)
  createdAt        DateTime  @default(now()) @map("created_at")
  wizardStep       Int       @default(1)

  usuarios         Usuario[]
  productos        Producto[]
  ventas           Venta[]
  alertas          Alerta[]
  categorias       Categoria[]

  @@map("tenants")
}

model Categoria {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  nombre    String
  createdAt DateTime @default(now()) @map("created_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nombre])
  @@map("categorias")
}

model Usuario {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  clerkUserId  String    @unique @map("clerk_user_id")
  nombre       String    @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  rol          Rol
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ventas       Venta[]
  movimientos  MovimientoStock[]

  @@map("usuarios")
}

model Producto {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  nombre      String    @db.VarChar(150)
  marca       String?   @db.VarChar(50)
  categoria   String?   @db.VarChar(50)
  descripcion String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variantes   VarianteProducto[]

  @@map("productos")
}

model VarianteProducto {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  productoId      String    @map("producto_id")
  sku             String    @db.VarChar(50)
  nombreVariante  String    @map("nombre_variante") @db.VarChar(100)
  imagenUrl       String?   @map("imagen_url")
  precioVenta     Decimal   @map("precio_venta") @db.Decimal(10, 2)
  stockActual     Int       @default(0) @map("stock_actual")
  stockMinimo     Int       @default(5) @map("stock_minimo")
  fechaCaducidad  DateTime? @map("fecha_caducidad") @db.Date
  updatedAt       DateTime  @updatedAt @map("updated_at")
  alertaLeida     Boolean   @default(false) @map("alerta_leida")

  producto        Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  detalles        DetalleVenta[]
  movimientos     MovimientoStock[]
  alertas         Alerta[]

  @@unique([tenantId, sku], name: "unique_sku_per_tenant")
  @@map("variantes_producto")
}

model Venta {
  id         String       @id @default(uuid())
  tenantId   String       @map("tenant_id")
  usuarioId  String       @map("usuario_id")
  total      Decimal      @db.Decimal(10, 2)
  estado     EstadoVenta  @default(PENDIENTE)
  createdAt  DateTime     @default(now()) @map("created_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario    Usuario      @relation(fields: [usuarioId], references: [id])
  detalles   DetalleVenta[]

  @@map("ventas")
}

model DetalleVenta {
  id              String           @id @default(uuid())
  ventaId         String           @map("venta_id")
  varianteId      String           @map("variante_id")
  cantidad        Int
  precioUnitario  Decimal          @map("precio_unitario") @db.Decimal(10, 2)

  venta           Venta            @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  variante        VarianteProducto @relation(fields: [varianteId], references: [id])

  @@map("detalle_ventas")
}

model MovimientoStock {
  id          String              @id @default(uuid())
  tenantId    String              @map("tenant_id")
  varianteId  String              @map("variante_id")
  tipo        TipoMovimiento
  cantidad    Int
  motivo      String?             @db.VarChar(255)
  usuarioId   String              @map("usuario_id")
  createdAt   DateTime            @default(now()) @map("created_at")

  variante    VarianteProducto    @relation(fields: [varianteId], references: [id])
  usuario     Usuario             @relation(fields: [usuarioId], references: [id])

  @@map("movimientos_stock")
}

model Alerta {
  id          String           @id @default(uuid())
  tenantId    String           @map("tenant_id")
  varianteId  String           @map("variante_id")
  tipo        TipoAlerta
  leida       Boolean          @default(false)
  createdAt   DateTime         @default(now()) @map("created_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variante    VarianteProducto @relation(fields: [varianteId], references: [id])

  @@map("alertas")
}

enum Rol {
  OWNER
  MANAGER
  EMPLOYEE
}

enum EstadoVenta {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

enum TipoMovimiento {
  ENTRADA
  AJUSTE
  MERMA
  CADUCADO
}

enum TipoAlerta {
  BAJO_STOCK
  CADUCIDAD_PROXIMA
  
}
